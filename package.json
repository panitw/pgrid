{
  "name": "@panitw/pgrid",
  "version": "2.3.0",
  "description": "A virtualized, extensible JavaScript data grid with frozen panes, inline editing, copy/paste, column resizing, and a pluggable extension API.",
  "main": "dist/pgrid.js",
  "module": "dist/pgrid.mjs",
  "style": "dist/pgrid.css",
  "exports": {
    ".": {
      "import": "./dist/pgrid.mjs",
      "require": "./dist/pgrid.js"
    },
    "./styles": "./dist/pgrid.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/panitw/pgrid.git"
  },
  "keywords": [
    "grid",
    "datagrid",
    "data-grid",
    "table",
    "virtualized",
    "virtual-scroll",
    "spreadsheet",
    "frozen-panes",
    "editable",
    "extensible"
  ],
  "author": "Panit Wechasil",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/register": "^7.23.7",
    "chai": "^4.4.1",
    "choices.js": "^3.0.4",
    "jsdom": "^24.1.3",
    "leche": "^2.3.0",
    "less": "^4.2.0",
    "lodash": "^4.17.21",
    "mocha": "^6.2.3",
    "numeral": "^2.0.6",
    "sinon": "^17.0.1",
    "vite": "^5.2.0"
  },
  "scripts": {
    "build": "vite build",
    "build:site": "vite build --mode site && node scripts/postbuild-site.mjs",
    "preview:site": "vite preview --outDir site --port 4173",
    "dev": "vite",
    "serve": "vite",
    "test": "mocha",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "resize-observer-polyfill": "^1.5.0"
  }
}
